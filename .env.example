# =============================================================================
# YouTube RAG Backend — Environment Configuration
# =============================================================================
# Infrastructure: Neon PostgreSQL (data) + Supabase Auth (identity) + OpenAI (LLM)
# Copy this file to `.env` and fill in your credentials before starting.
# =============================================================================

# ── External API Keys ────────────────────────────────────────────────────────
PINECONE_API_KEY=
OPENAI_API_KEY=

# ── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Neon serverless Postgres via connection pooler.
# Docs: https://neon.tech/docs/connect/connect-from-any-app
DATABASE_URL=postgresql://user:password@ep-example-pooler.region.aws.neon.tech/neondb?sslmode=require

# ── Authentication (Supabase Auth) ───────────────────────────────────────────
# Supabase is used *only* for authentication (JWT issuance & verification).
# The database itself is hosted on Neon — these two services are independent.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_JWT_SECRET=
SUPABASE_KEY=

# ── LLM / RAG Configuration ─────────────────────────────────────────────────
MODEL_NAME=gpt-5.4-mini
CHROMA_PERSIST_DIRECTORY=db

# ── Application ──────────────────────────────────────────────────────────────
APP_LOG_FILE=logs/app.log
PORT=8080
